# Neon: Pooled connection (앱 런타임용, -pooler 호스트)
DATABASE_URL=postgresql://user:password@ep-xxx-pooler.region.aws.neon.tech/jsure?sslmode=require
# Neon: Direct connection (Prisma migrate 전용, -pooler 없는 호스트)
DIRECT_URL=postgresql://user:password@ep-xxx.region.aws.neon.tech/jsure?sslmode=require

# JWT 설정
JWT_SECRET=replace-me-with-a-long-random-string
JWT_EXPIRES_IN=15m
# 어드민 Refresh 토큰 TTL (일 단위). 세션 회전 시 갱신됨.
REFRESH_EXPIRES_DAYS=14
# 인플루언서 Refresh 토큰 TTL (일 단위). 미설정 시 30일.
INFLUENCER_REFRESH_EXPIRES_DAYS=30

# 서버
PORT=3000
NODE_ENV=development

# CORS — Vercel에 배포된 web 도메인을 허용
CORS_ORIGIN=http://localhost:5173

# 인플루언서용 client-web 호스트. LINE 알림에 포함되는 신청 페이지 링크에 사용됨.
APP_BASE_URL=http://localhost:5174

# Cloudflare R2 (파일 업로드)
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
# 공개 자산 버킷 (캠페인 썸네일·공지 이미지 등)
R2_BUCKET=jsure-uploads
# 개인 데이터 버킷 (인사이트 스크린샷·제출물 첨부). 미설정 시 R2_BUCKET 사용.
R2_PRIVATE_BUCKET=jsure-private
# R2_BUCKET 의 퍼블릭 도메인 (커스텀 도메인 또는 r2.dev). 설정 시 공개 자산은 만료 없는 URL 로 제공.
R2_PUBLIC_BASE_URL=
