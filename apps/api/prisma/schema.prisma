generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model AdminUser {
  id           String          @id @default(cuid())
  email        String          @unique
  passwordHash String
  name         String?
  role         AdminUserRole   @default(GUEST)
  status       AdminUserStatus @default(PENDING)
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt

  sessions AdminUserSession[]

  @@map("admin_users")
}

model AdminUserSession {
  id               String    @id @default(cuid())
  adminUserId      String
  refreshTokenHash String    @unique
  userAgent        String?
  ip               String?
  createdAt        DateTime  @default(now())
  lastSeenAt       DateTime  @default(now())
  expiresAt        DateTime
  revokedAt        DateTime?

  adminUser AdminUser @relation(fields: [adminUserId], references: [id], onDelete: Cascade)

  @@index([adminUserId])
  @@map("admin_user_sessions")
}

enum AdminUserRole {
  GUEST
  ADMIN
  OWNER
}

enum AdminUserStatus {
  PENDING
  ACTIVE
  SUSPENDED
}

model Campaign {
  id                 String   @id @default(cuid())
  title              String
  rewardJpy          Int
  snsTypes           String[]
  condition          String
  recruitCount       Int
  recruitStartAt     DateTime
  recruitEndAt       DateTime
  productSummary     String
  productDetailUrl   String
  guideline          String
  referenceMediaUrls String[]
  cautions           String
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  @@index([recruitStartAt])
  @@map("campaigns")
}
