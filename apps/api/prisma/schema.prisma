generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model AdminUser {
  id           String          @id @default(cuid())
  email        String          @unique
  passwordHash String
  name         String?
  role         AdminUserRole   @default(GUEST)
  status       AdminUserStatus @default(PENDING)
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt
  testLineUserId String?

  sessions             AdminUserSession[]
  notices              Notice[]
  lineMessageTemplates LineMessageTemplate[]

  @@map("admin_users")
}

model AdminUserSession {
  id               String    @id @default(cuid())
  adminUserId      String
  refreshTokenHash String    @unique
  userAgent        String?
  ip               String?
  createdAt        DateTime  @default(now())
  lastSeenAt       DateTime  @default(now())
  expiresAt        DateTime
  revokedAt        DateTime?

  adminUser AdminUser @relation(fields: [adminUserId], references: [id], onDelete: Cascade)

  @@index([adminUserId])
  @@map("admin_user_sessions")
}

enum AdminUserRole {
  GUEST
  ADMIN
  OWNER
}

enum AdminUserStatus {
  PENDING
  ACTIVE
  SUSPENDED
}

enum CampaignSubType {
  INSTAGRAM
  TIKTOK
  X
  YOUTUBE
  QOO10
}

enum InstagramPostType {
  FEED
  REELS
}

enum InfluencerStatus {
  ACTIVE
  SUSPENDED
}

enum ApplicationStatus {
  APPLIED
  REJECTED
  APPROVED
  SHIPPED
  DELIVERED
  COMPLETED
  CANCELLED
  ORDER_SUBMITTED
  REVIEW_SUBMITTED
}

enum PostReviewStatus {
  PENDING
  APPROVED
  REJECTED
}

model Campaign {
  id                 String           @id @default(cuid())
  category           CampaignCategory @default(SNS)
  title              String
  rewardJpy          Int
  recruitStartAt     DateTime
  recruitEndAt       DateTime
  closedAt           DateTime?
  postingPeriodDays  Int       @default(14)
  productSummary     String
  productDetailUrl   String
  guideline          String
  referenceMediaUrls String[]
  cautions           String
  thumbnailUrl       String?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  recruits     CampaignRecruit[]
  applications CampaignApplication[]
  influencerMemos InfluencerMemo[]

  // 이 캠페인이 "제외 대상" 으로 지정한 다른 캠페인들 (E → A,B)
  exclusionsAsExcluding CampaignExclusion[] @relation("excludingCampaign")
  // 이 캠페인이 다른 캠페인에 의해 "제외 대상" 으로 지정된 관계 (역방향)
  exclusionsAsExcluded  CampaignExclusion[] @relation("excludedCampaign")

  @@index([recruitStartAt])
  @@map("campaigns")
}

// 캠페인 응모 시 제외(exclusion) 관계.
// campaignId 가 신규/현재 캠페인 (E), excludedCampaignId 가 응모 이력이 있으면
// 이 캠페인 응모를 막을 기준 캠페인 (A,B).
model CampaignExclusion {
  id                 String   @id @default(cuid())
  campaignId         String
  excludedCampaignId String
  createdAt          DateTime @default(now())

  campaign         Campaign @relation("excludingCampaign", fields: [campaignId], references: [id], onDelete: Cascade)
  excludedCampaign Campaign @relation("excludedCampaign", fields: [excludedCampaignId], references: [id], onDelete: Cascade)

  @@unique([campaignId, excludedCampaignId])
  @@index([excludedCampaignId])
  @@map("campaign_exclusions")
}

model CampaignRecruit {
  id                 String              @id @default(cuid())
  campaignId         String
  subType            CampaignSubType
  minFollowers       Int                 @default(0)
  recruitCount       Int
  subTypeOptions     String[]            @default([])
  insightRequired    Boolean             @default(true)
  productPriceJpy    Int?
  productUrl         String?
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt

  campaign Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  @@unique([campaignId, subType])
  @@map("campaign_recruits")
}

model Influencer {
  id            String               @id @default(cuid())
  email         String               @unique
  passwordHash  String?
  lineUserId    String?              @unique
  lineLinkedAt  DateTime?
  name          String
  nameKana      String?
  phone         String
  birthDate     DateTime?
  postalCode    String               @default("")
  prefecture    String               @default("")
  city          String               @default("")
  addressLine1  String               @default("")
  addressLine2  String               @default("")
  memo          String?
  status        InfluencerStatus     @default(ACTIVE)
  flaggedAt     DateTime?
  flaggedById   String?
  createdAt     DateTime             @default(now())
  updatedAt     DateTime             @updatedAt

  snsAccounts  InfluencerSnsAccount[]
  applications CampaignApplication[]
  consents     InfluencerConsent[]
  bankAccount  InfluencerBankAccount?
  sessions     InfluencerSession[]
  memos        InfluencerMemo[]

  @@map("influencers")
}

model InfluencerMemo {
  id           String   @id @default(cuid())
  influencerId String
  campaignId   String?
  comment      String
  createdAt    DateTime @default(now())
  createdById  String?

  influencer Influencer @relation(fields: [influencerId], references: [id], onDelete: Cascade)
  campaign   Campaign?  @relation(fields: [campaignId], references: [id], onDelete: SetNull)

  @@index([influencerId])
  @@map("influencer_memos")
}

model InfluencerSession {
  id               String    @id @default(cuid())
  influencerId     String
  refreshTokenHash String    @unique
  userAgent        String?
  ip               String?
  createdAt        DateTime  @default(now())
  lastSeenAt       DateTime  @default(now())
  expiresAt        DateTime
  revokedAt        DateTime?

  influencer Influencer @relation(fields: [influencerId], references: [id], onDelete: Cascade)

  @@index([influencerId])
  @@map("influencer_sessions")
}

model InfluencerSnsAccount {
  id            String   @id @default(cuid())
  influencerId  String
  snsType       CampaignSubType
  handle        String
  followerCount Int      @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  influencer Influencer @relation(fields: [influencerId], references: [id], onDelete: Cascade)

  @@unique([influencerId, snsType])
  @@map("influencer_sns_accounts")
}

model InfluencerConsent {
  id           String   @id @default(cuid())
  influencerId String
  termsVersion String
  agreedItems  String[]
  agreedAt     DateTime @default(now())
  ip           String?
  userAgent    String?

  influencer Influencer @relation(fields: [influencerId], references: [id], onDelete: Cascade)

  @@index([influencerId, termsVersion])
  @@map("influencer_consents")
}

model InfluencerBankAccount {
  id                String               @id @default(cuid())
  influencerId      String               @unique
  bankCode          String
  bankName          String
  branchName        String
  branchCode        String               @default("")
  accountNumber     String
  accountHolderKana String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  influencer Influencer @relation(fields: [influencerId], references: [id], onDelete: Cascade)

  @@map("influencer_bank_accounts")
}

model CampaignApplication {
  id           String            @id @default(cuid())
  campaignId   String
  influencerId String
  subType      CampaignSubType
  /// INSTAGRAM 응모일 때만 의미가 있다. 비-INSTAGRAM 응모는 항상 null.
  instagramPostType InstagramPostType?
  status       ApplicationStatus @default(APPLIED)

  appliedAt    DateTime  @default(now())
  reviewedAt   DateTime?
  reviewedById String?
  rejectReason String?

  trackingCarrier String?
  trackingNumber  String?
  shippedAt       DateTime?
  deliveredAt    DateTime?
  receivedAt     DateTime?
  completedAt    DateTime?

  orderNumber        String?
  orderSubmittedAt   DateTime?
  reviewSubmittedAt  DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  campaign   Campaign        @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  influencer Influencer      @relation(fields: [influencerId], references: [id], onDelete: Restrict)
  posts      SubmittedPost[]
  attachments Attachment[]
  lineDispatchLogs LineDispatchLog[]

  @@unique([campaignId, influencerId, subType])
  @@index([campaignId, status])
  @@index([influencerId, status])
  @@map("campaign_applications")
}

model SubmittedPost {
  id                  String    @id @default(cuid())
  applicationId       String
  subType             CampaignSubType
  url                 String?
  submissionData      Json?
  submittedAt         DateTime  @default(now())
  insightLikes        Int?
  insightComments     Int?
  insightShares       Int?
  insightReposts      Int?
  insightSaves        Int?
  insightViews        Int?
  insightReach        Int?
  insightProfileViews Int?
  insightSubmittedAt  DateTime?
  updatedAt           DateTime  @updatedAt

  reviewStatus PostReviewStatus @default(PENDING)
  reviewedAt   DateTime?
  reviewedById String?

  settledAt        DateTime?
  settledAmountJpy Int?
  settledById      String?

  settlementCompletedAt   DateTime?
  settlementCompletedById String?

  application CampaignApplication      @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  rejections  SubmittedPostRejection[]
  attachments Attachment[]
  settlement  Settlement?

  @@unique([applicationId, subType])
  @@index([applicationId])
  @@index([reviewStatus])
  @@map("submitted_posts")
}

enum SettlementStatus {
  PENDING
  COMPLETED
}

model Settlement {
  id            String           @id @default(cuid())
  postId        String           @unique
  amountJpy     Int
  rewardAmountJpy   Int              @default(0)
  productRefundJpy  Int              @default(0)
  status        SettlementStatus @default(PENDING)
  createdAt     DateTime         @default(now())
  completedAt   DateTime?
  completedById String?

  post SubmittedPost @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@index([status])
  @@map("settlements")
}

model Attachment {
  id            String              @id @default(cuid())
  kind          AttachmentKind
  applicationId String
  postId        String?
  objectKey     String              @unique
  contentType   String
  sizeBytes     Int
  uploadedAt    DateTime            @default(now())

  application CampaignApplication @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  post        SubmittedPost?      @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@index([applicationId, kind])
  @@index([postId, kind])
  @@map("attachments")
}

model SubmittedPostRejection {
  id           String   @id @default(cuid())
  postId       String
  comment      String
  rejectedAt   DateTime @default(now())
  rejectedById String?

  post SubmittedPost @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@index([postId])
  @@map("submitted_post_rejections")
}

model Notice {
  id          String   @id @default(cuid())
  title       String
  contentHtml String
  startAt     DateTime
  endAt       DateTime
  authorId    String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  author AdminUser @relation(fields: [authorId], references: [id])

  @@index([startAt])
  @@index([endAt])
  @@map("notices")
}

enum BroadcastJobStatus {
  QUEUED
  RUNNING
  COMPLETED
  FAILED
}

model BroadcastJob {
  id              String             @id @default(cuid())
  status          BroadcastJobStatus @default(QUEUED)
  total           Int                @default(0)
  sent            Int                @default(0)
  failed          Int                @default(0)
  skipped         Int                @default(0)
  contentHtml     String
  heroImageR2Key  String?
  altText         String?
  errorMessage    String?
  createdById     String
  influencerIds   String[]
  createdAt       DateTime           @default(now())
  startedAt       DateTime?
  finishedAt      DateTime?

  @@index([status, createdAt])
  @@map("broadcast_jobs")
}

enum CampaignCategory {
  SNS
  FAKE_PURCHASE
}

enum LineTriggerKey {
  SNS_APPLICATION_APPLIED
  SNS_APPLICATION_APPROVED
  SNS_APPLICATION_REJECTED
  SNS_APPLICATION_SHIPPED
  SNS_APPLICATION_DELIVERED
  SNS_APPLICATION_RECEIPT_CONFIRMED
  SNS_POST_SUBMITTED
  SNS_POST_DEADLINE_REMINDER
  SNS_POST_APPROVED
  SNS_POST_REJECTED
  SNS_POST_REJECTION_REMINDER
  SNS_INSIGHT_SUBMITTED
  SNS_INSIGHT_APPROVED
  SNS_INSIGHT_REMINDER
  SNS_SETTLEMENT_COMPLETED
  SNS_CAMPAIGN_COMPLETED
  FAKE_PURCHASE_APPLICATION_APPLIED
  FAKE_PURCHASE_APPLICATION_APPROVED
  FAKE_PURCHASE_APPLICATION_REJECTED
  FAKE_PURCHASE_ORDER_SUBMITTED
  FAKE_PURCHASE_REVIEW_SUBMITTED
  FAKE_PURCHASE_REVIEW_APPROVED
  FAKE_PURCHASE_REVIEW_REJECTED
  FAKE_PURCHASE_REVIEW_DEADLINE_REMINDER
  FAKE_PURCHASE_SETTLEMENT_COMPLETED
  FAKE_PURCHASE_CAMPAIGN_COMPLETED
}

enum AttachmentKind {
  INSIGHT_SCREENSHOT
  ORDER_RECEIPT
  REVIEW_SCREENSHOT
}

enum LineTriggerSubType {
  INSTAGRAM
  X
  QOO10
}

enum LineDispatchStatus {
  SUCCESS
  FAILED
  SKIPPED_DISABLED
  SKIPPED_NO_TEMPLATE
}

model LineMessageTemplate {
  id          String           @id @default(cuid())
  category    CampaignCategory
  triggerKey  LineTriggerKey
  enabled     Boolean          @default(false)
  body        String
  updatedAt   DateTime         @updatedAt
  updatedById String?

  updatedBy    AdminUser?        @relation(fields: [updatedById], references: [id], onDelete: SetNull)
  dispatchLogs LineDispatchLog[]

  @@unique([category, triggerKey])
  @@map("line_message_templates")
}

model LineDispatchLog {
  id            String                 @id @default(cuid())
  category      CampaignCategory
  subType       LineTriggerSubType?
  triggerKey    LineTriggerKey
  templateId    String?
  template      LineMessageTemplate?   @relation(fields: [templateId], references: [id], onDelete: SetNull)
  applicationId String?
  application   CampaignApplication?   @relation(fields: [applicationId], references: [id], onDelete: SetNull)
  toLineUserId  String
  renderedBody  String
  status        LineDispatchStatus
  errorMessage  String?
  createdAt     DateTime               @default(now())

  @@index([applicationId, triggerKey])
  @@index([createdAt])
  @@map("line_dispatch_logs")
}
