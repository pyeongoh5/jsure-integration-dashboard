generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model AdminUser {
  id           String          @id @default(cuid())
  email        String          @unique
  passwordHash String
  name         String?
  role         AdminUserRole   @default(GUEST)
  status       AdminUserStatus @default(PENDING)
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt
  testLineUserId String?

  sessions             AdminUserSession[]
  notices              Notice[]
  lineMessageTemplates LineMessageTemplate[]

  @@map("admin_users")
}

model AdminUserSession {
  id               String    @id @default(cuid())
  adminUserId      String
  refreshTokenHash String    @unique
  userAgent        String?
  ip               String?
  createdAt        DateTime  @default(now())
  lastSeenAt       DateTime  @default(now())
  expiresAt        DateTime
  revokedAt        DateTime?

  adminUser AdminUser @relation(fields: [adminUserId], references: [id], onDelete: Cascade)

  @@index([adminUserId])
  @@map("admin_user_sessions")
}

enum AdminUserRole {
  GUEST
  ADMIN
  OWNER
}

enum AdminUserStatus {
  PENDING
  ACTIVE
  SUSPENDED
}

enum CampaignSubType {
  INSTAGRAM
  TIKTOK
  X
  YOUTUBE
  QOO10
  LIPS
  ATCOSME
}

enum InfluencerStatus {
  ACTIVE
  SUSPENDED
}

enum ApplicationStatus {
  APPLIED
  REJECTED
  APPROVED
  SHIPPED
  DELIVERED
  COMPLETED
  CANCELLED
  ORDER_SUBMITTED
  REVIEW_SUBMITTED
}

enum PostReviewStatus {
  PENDING
  APPROVED
  REJECTED
}

// 보수 체계.
// - UNIFIED: 참여 서브타입 수와 무관하게 Campaign.rewardJpy 고정 지급.
// - PER_SUBTYPE: 참여한 서브타입별 CampaignRecruit.rewardJpy 합산 지급.
enum RewardType {
  UNIFIED
  PER_SUBTYPE
}

model Campaign {
  id                 String           @id @default(cuid())
  category           CampaignCategory @default(SNS)
  title              String
  rewardType         RewardType       @default(UNIFIED)
  /// UNIFIED 캠페인의 보수 금액. PER_SUBTYPE 캠페인에서는 사용하지 않는다.
  rewardJpy          Int
  recruitStartAt     DateTime
  recruitEndAt       DateTime
  closedAt           DateTime?
  postingPeriodDays  Int       @default(14)
  productSummary     String
  productDetailUrls  String[]
  guideline          String
  referenceMediaUrls String[]
  cautions           String
  thumbnailUrl       String?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  recruits     CampaignRecruit[]
  applications CampaignApplication[]
  influencerMemos InfluencerMemo[]

  // 이 캠페인이 "제외 대상" 으로 지정한 다른 캠페인들 (E → A,B)
  exclusionsAsExcluding CampaignExclusion[] @relation("excludingCampaign")
  // 이 캠페인이 다른 캠페인에 의해 "제외 대상" 으로 지정된 관계 (역방향)
  exclusionsAsExcluded  CampaignExclusion[] @relation("excludedCampaign")

  @@index([recruitStartAt])
  @@map("campaigns")
}

// 캠페인 응모 시 제외(exclusion) 관계.
// campaignId 가 신규/현재 캠페인 (E), excludedCampaignId 가 응모 이력이 있으면
// 이 캠페인 응모를 막을 기준 캠페인 (A,B).
model CampaignExclusion {
  id                 String   @id @default(cuid())
  campaignId         String
  excludedCampaignId String
  createdAt          DateTime @default(now())

  campaign         Campaign @relation("excludingCampaign", fields: [campaignId], references: [id], onDelete: Cascade)
  excludedCampaign Campaign @relation("excludedCampaign", fields: [excludedCampaignId], references: [id], onDelete: Cascade)

  @@unique([campaignId, excludedCampaignId])
  @@index([excludedCampaignId])
  @@map("campaign_exclusions")
}

model CampaignRecruit {
  id                 String              @id @default(cuid())
  campaignId         String
  subType            CampaignSubType
  minFollowers       Int                 @default(0)
  recruitCount       Int
  /// PER_SUBTYPE 캠페인용: 이 서브타입 참여 보수(JPY). UNIFIED 캠페인은 null.
  rewardJpy          Int?
  subTypeOptions     String[]            @default([])
  insightRequired    Boolean             @default(true)
  isRequired         Boolean             @default(false)
  productPriceJpy    Int?
  productUrl         String?
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt

  campaign Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  options  CampaignRecruitOption[]

  @@unique([campaignId, subType])
  @@map("campaign_recruits")
}

/// recruit가 모집하는 옵션(FEED/REELS 등)의 세부 설정. 속성별 all-or-nothing:
/// 모든 행에 recruitCount 존재 = 정원 분리(부모 recruitCount = 합계),
/// 모든 행에 rewardJpy 존재 = 보수 분리(부모 rewardJpy = null 강제).
model CampaignRecruitOption {
  id           String @id @default(cuid())
  recruitId    String
  /// subTypeOptions 값 축: "FEED" | "REELS" | (미래: "LIPS" | "ATCOSME")
  option       String
  recruitCount Int?
  rewardJpy    Int?

  recruit CampaignRecruit @relation(fields: [recruitId], references: [id], onDelete: Cascade)

  @@unique([recruitId, option])
  @@map("campaign_recruit_options")
}

model Influencer {
  id            String               @id @default(cuid())
  email         String               @unique
  passwordHash  String?
  lineUserId    String?              @unique
  lineLinkedAt  DateTime?
  name          String
  nameKana      String?
  phone         String
  birthDate     DateTime?
  postalCode    String               @default("")
  prefecture    String               @default("")
  city          String               @default("")
  addressLine1  String               @default("")
  addressLine2  String               @default("")
  memo          String?
  status        InfluencerStatus     @default(ACTIVE)
  flaggedAt     DateTime?
  flaggedById   String?
  createdAt     DateTime             @default(now())
  updatedAt     DateTime             @updatedAt

  snsAccounts  InfluencerSnsAccount[]
  applications CampaignApplication[]
  consents     InfluencerConsent[]
  bankAccount  InfluencerBankAccount?
  sessions     InfluencerSession[]
  memos        InfluencerMemo[]

  @@map("influencers")
}

model InfluencerMemo {
  id           String   @id @default(cuid())
  influencerId String
  campaignId   String?
  comment      String
  createdAt    DateTime @default(now())
  createdById  String?

  influencer Influencer @relation(fields: [influencerId], references: [id], onDelete: Cascade)
  campaign   Campaign?  @relation(fields: [campaignId], references: [id], onDelete: SetNull)

  @@index([influencerId])
  @@map("influencer_memos")
}

model InfluencerSession {
  id               String    @id @default(cuid())
  influencerId     String
  refreshTokenHash String    @unique
  userAgent        String?
  ip               String?
  createdAt        DateTime  @default(now())
  lastSeenAt       DateTime  @default(now())
  expiresAt        DateTime
  revokedAt        DateTime?

  influencer Influencer @relation(fields: [influencerId], references: [id], onDelete: Cascade)

  @@index([influencerId])
  @@map("influencer_sessions")
}

model InfluencerSnsAccount {
  id            String   @id @default(cuid())
  influencerId  String
  snsType       CampaignSubType
  handle        String
  followerCount Int      @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  influencer Influencer @relation(fields: [influencerId], references: [id], onDelete: Cascade)

  @@unique([influencerId, snsType])
  @@map("influencer_sns_accounts")
}

model InfluencerConsent {
  id           String   @id @default(cuid())
  influencerId String
  termsVersion String
  agreedItems  String[]
  agreedAt     DateTime @default(now())
  ip           String?
  userAgent    String?

  influencer Influencer @relation(fields: [influencerId], references: [id], onDelete: Cascade)

  @@index([influencerId, termsVersion])
  @@map("influencer_consents")
}

model InfluencerBankAccount {
  id                String               @id @default(cuid())
  influencerId      String               @unique
  bankCode          String
  bankName          String
  branchName        String
  branchCode        String               @default("")
  accountNumber     String
  accountHolderKana String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  influencer Influencer @relation(fields: [influencerId], references: [id], onDelete: Cascade)

  @@map("influencer_bank_accounts")
}

model CampaignApplication {
  id           String            @id @default(cuid())
  campaignId   String
  influencerId String
  /// 이 응모가 참여하는 서브타입 목록.
  subTypes     CampaignSubType[]
  status       ApplicationStatus @default(APPLIED)

  appliedAt    DateTime  @default(now())
  reviewedAt   DateTime?
  reviewedById String?
  rejectReason String?

  trackingCarrier String?
  trackingNumber  String?
  shippedAt       DateTime?
  deliveredAt    DateTime?
  receivedAt     DateTime?
  completedAt    DateTime?

  orderNumber        String?
  orderSubmittedAt   DateTime?
  /// 제출물(게시물/리뷰) 최종 제출 시각 — 전 카테고리 공통.
  reviewSubmittedAt  DateTime?

  /// 제출물(전체) 검토 상태 — 응모 단위 전체 승인/반려.
  submissionReviewStatus PostReviewStatus @default(PENDING)
  submissionReviewedAt   DateTime?
  submissionReviewedById String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  campaign   Campaign        @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  influencer Influencer      @relation(fields: [influencerId], references: [id], onDelete: Restrict)
  posts      SubmittedPost[]
  attachments Attachment[]
  lineDispatchLogs LineDispatchLog[]
  submissionRejections SubmissionRejection[]
  settlement Settlement?
  options    CampaignApplicationOption[]

  @@unique([campaignId, influencerId])
  @@index([campaignId, status])
  @@index([influencerId, status])
  @@map("campaign_applications")
}

/// 응모가 선택한 서브타입 옵션 (구 instagramPostType 의 일반화).
/// 현재는 INSTAGRAM 의 FEED/REELS 단일 선택만 사용하지만, 서브타입·복수 선택으로
/// 확장 가능한 구조.
model CampaignApplicationOption {
  id            String          @id @default(cuid())
  applicationId String
  subType       CampaignSubType
  option        String

  application CampaignApplication @relation(fields: [applicationId], references: [id], onDelete: Cascade)

  @@unique([applicationId, subType, option])
  @@map("campaign_application_options")
}

// 서브타입별 제출 데이터(게시물 URL, 인사이트 지표). 검토/정산은 응모 단위로 진행된다.
model SubmittedPost {
  id                  String    @id @default(cuid())
  applicationId       String
  subType             CampaignSubType
  url                 String?
  submissionData      Json?
  submittedAt         DateTime  @default(now())
  insightLikes        Int?
  insightComments     Int?
  insightShares       Int?
  insightReposts      Int?
  insightSaves        Int?
  insightViews        Int?
  insightReach        Int?
  insightProfileViews Int?
  insightSubmittedAt  DateTime?
  updatedAt           DateTime  @updatedAt

  application CampaignApplication @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  attachments Attachment[]

  @@unique([applicationId, subType])
  @@index([applicationId])
  @@map("submitted_posts")
}

enum SettlementStatus {
  PENDING
  COMPLETED
}

model Settlement {
  id            String           @id @default(cuid())
  applicationId String           @unique
  amountJpy     Int
  rewardAmountJpy   Int              @default(0)
  productRefundJpy  Int              @default(0)
  status        SettlementStatus @default(PENDING)
  createdAt     DateTime         @default(now())
  completedAt   DateTime?
  completedById String?

  /// 정산 생성(대기풀 진입) 시점의 계좌 스냅샷 — 이후 마이페이지 변경과 무관하게 보존.
  /// 스냅샷 도입 전 생성된 정산은 null (조회 시 현재 계좌로 fallback).
  bankCode          String?
  bankName          String?
  branchName        String?
  branchCode        String?
  accountNumber     String?
  accountHolderKana String?

  application CampaignApplication @relation(fields: [applicationId], references: [id], onDelete: Cascade)

  @@index([status])
  @@map("settlements")
}

model Attachment {
  id            String              @id @default(cuid())
  kind          AttachmentKind
  applicationId String
  postId        String?
  objectKey     String              @unique
  contentType   String
  sizeBytes     Int
  uploadedAt    DateTime            @default(now())

  application CampaignApplication @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  post        SubmittedPost?      @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@index([applicationId, kind])
  @@index([postId, kind])
  @@map("attachments")
}

// 응모 단위 제출물 반려 이력.
model SubmissionRejection {
  id            String   @id @default(cuid())
  applicationId String
  comment       String
  rejectedAt    DateTime @default(now())
  rejectedById  String?

  application CampaignApplication @relation(fields: [applicationId], references: [id], onDelete: Cascade)

  @@index([applicationId])
  @@map("submitted_post_rejections")
}

model Notice {
  id          String   @id @default(cuid())
  title       String
  contentHtml String
  startAt     DateTime
  endAt       DateTime
  authorId    String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  author AdminUser @relation(fields: [authorId], references: [id])

  @@index([startAt])
  @@index([endAt])
  @@map("notices")
}

enum BroadcastJobStatus {
  QUEUED
  RUNNING
  COMPLETED
  FAILED
}

model BroadcastJob {
  id              String             @id @default(cuid())
  status          BroadcastJobStatus @default(QUEUED)
  total           Int                @default(0)
  sent            Int                @default(0)
  failed          Int                @default(0)
  skipped         Int                @default(0)
  contentHtml     String
  heroImageR2Key  String?
  altText         String?
  errorMessage    String?
  createdById     String
  influencerIds   String[]
  createdAt       DateTime           @default(now())
  startedAt       DateTime?
  finishedAt      DateTime?

  @@index([status, createdAt])
  @@map("broadcast_jobs")
}

enum CampaignCategory {
  SNS
  FAKE_PURCHASE
  SIMPLE_REVIEW
}

enum LineTriggerKey {
  SNS_APPLICATION_APPLIED
  SNS_APPLICATION_APPROVED
  SNS_APPLICATION_REJECTED
  SNS_APPLICATION_SHIPPED
  SNS_APPLICATION_DELIVERED
  SNS_APPLICATION_RECEIPT_CONFIRMED
  SNS_POST_SUBMITTED
  SNS_POST_DEADLINE_REMINDER
  SNS_POST_APPROVED
  SNS_POST_REJECTED
  SNS_POST_REJECTION_REMINDER
  SNS_INSIGHT_SUBMITTED
  SNS_INSIGHT_REMINDER
  SNS_INSIGHT_OVERDUE_REMINDER
  SNS_SETTLEMENT_COMPLETED
  SNS_CAMPAIGN_COMPLETED
  FAKE_PURCHASE_APPLICATION_APPLIED
  FAKE_PURCHASE_APPLICATION_APPROVED
  FAKE_PURCHASE_APPLICATION_REJECTED
  FAKE_PURCHASE_ORDER_SUBMITTED
  FAKE_PURCHASE_REVIEW_SUBMITTED
  FAKE_PURCHASE_REVIEW_APPROVED
  FAKE_PURCHASE_REVIEW_REJECTED
  FAKE_PURCHASE_REVIEW_DEADLINE_REMINDER
  FAKE_PURCHASE_SETTLEMENT_COMPLETED
  FAKE_PURCHASE_CAMPAIGN_COMPLETED
  SIMPLE_REVIEW_APPLICATION_APPLIED
  SIMPLE_REVIEW_APPLICATION_APPROVED
  SIMPLE_REVIEW_APPLICATION_REJECTED
  SIMPLE_REVIEW_APPLICATION_SHIPPED
  SIMPLE_REVIEW_APPLICATION_DELIVERED
  SIMPLE_REVIEW_APPLICATION_RECEIPT_CONFIRMED
  SIMPLE_REVIEW_SUBMITTED
  SIMPLE_REVIEW_APPROVED
  SIMPLE_REVIEW_REJECTED
  SIMPLE_REVIEW_DEADLINE_REMINDER
  SIMPLE_REVIEW_REJECTION_REMINDER
  SIMPLE_REVIEW_SETTLEMENT_COMPLETED
  SIMPLE_REVIEW_CAMPAIGN_COMPLETED
}

enum AttachmentKind {
  INSIGHT_SCREENSHOT
  ORDER_RECEIPT
  REVIEW_SCREENSHOT
}

enum LineTriggerSubType {
  INSTAGRAM
  X
  QOO10
}

enum LineDispatchStatus {
  SUCCESS
  FAILED
  SKIPPED_DISABLED
  SKIPPED_NO_TEMPLATE
}

model LineMessageTemplate {
  id          String           @id @default(cuid())
  category    CampaignCategory
  triggerKey  LineTriggerKey
  enabled     Boolean          @default(false)
  body        String
  updatedAt   DateTime         @updatedAt
  updatedById String?

  updatedBy    AdminUser?        @relation(fields: [updatedById], references: [id], onDelete: SetNull)
  dispatchLogs LineDispatchLog[]

  @@unique([category, triggerKey])
  @@map("line_message_templates")
}

model LineDispatchLog {
  id            String                 @id @default(cuid())
  category      CampaignCategory
  subType       LineTriggerSubType?
  triggerKey    LineTriggerKey
  templateId    String?
  template      LineMessageTemplate?   @relation(fields: [templateId], references: [id], onDelete: SetNull)
  applicationId String?
  application   CampaignApplication?   @relation(fields: [applicationId], references: [id], onDelete: SetNull)
  toLineUserId  String
  renderedBody  String
  status        LineDispatchStatus
  errorMessage  String?
  createdAt     DateTime               @default(now())

  @@index([applicationId, triggerKey])
  @@index([createdAt])
  @@map("line_dispatch_logs")
}
