generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model AdminUser {
  id           String          @id @default(cuid())
  email        String          @unique
  passwordHash String
  name         String?
  role         AdminUserRole   @default(GUEST)
  status       AdminUserStatus @default(PENDING)
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt

  sessions AdminUserSession[]
  notices  Notice[]

  @@map("admin_users")
}

model AdminUserSession {
  id               String    @id @default(cuid())
  adminUserId      String
  refreshTokenHash String    @unique
  userAgent        String?
  ip               String?
  createdAt        DateTime  @default(now())
  lastSeenAt       DateTime  @default(now())
  expiresAt        DateTime
  revokedAt        DateTime?

  adminUser AdminUser @relation(fields: [adminUserId], references: [id], onDelete: Cascade)

  @@index([adminUserId])
  @@map("admin_user_sessions")
}

enum AdminUserRole {
  GUEST
  ADMIN
  OWNER
}

enum AdminUserStatus {
  PENDING
  ACTIVE
  SUSPENDED
}

enum SnsType {
  INSTAGRAM
  TIKTOK
  X
  YOUTUBE
}

enum InfluencerEntityType {
  INDIVIDUAL
  CORPORATE
}

enum InfluencerStatus {
  ACTIVE
  SUSPENDED
}

enum JpAccountType {
  FUTSU
  TOUZA
}

enum ApplicationStatus {
  APPLIED
  REJECTED
  APPROVED
  SHIPPED
  DELIVERED
  COMPLETED
  CANCELLED
}

enum PostReviewStatus {
  PENDING
  APPROVED
  REJECTED
}

model Campaign {
  id                 String    @id @default(cuid())
  title              String
  rewardJpy          Int
  recruitStartAt     DateTime
  recruitEndAt       DateTime
  closedAt           DateTime?
  postingPeriodDays  Int       @default(14)
  productSummary     String
  productDetailUrl   String
  guideline          String
  referenceMediaUrls String[]
  cautions           String
  thumbnailUrl       String?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  snsRecruits  CampaignSnsRecruit[]
  applications CampaignApplication[]

  @@index([recruitStartAt])
  @@map("campaigns")
}

model CampaignSnsRecruit {
  id           String   @id @default(cuid())
  campaignId   String
  snsType      SnsType
  minFollowers Int      @default(0)
  recruitCount Int
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  campaign Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  @@unique([campaignId, snsType])
  @@index([campaignId])
  @@map("campaign_sns_recruits")
}

model Influencer {
  id           String               @id @default(cuid())
  email        String               @unique
  passwordHash String?
  lineUserId   String?              @unique
  lineLinkedAt DateTime?
  name         String
  nameKana     String?
  phone        String
  entityType   InfluencerEntityType
  memo         String?
  status       InfluencerStatus     @default(ACTIVE)
  createdAt    DateTime             @default(now())
  updatedAt    DateTime             @updatedAt

  snsAccounts  InfluencerSnsAccount[]
  applications CampaignApplication[]
  consents     InfluencerConsent[]
  bankAccount  InfluencerBankAccount?
  sessions     InfluencerSession[]

  @@map("influencers")
}

model InfluencerSession {
  id               String    @id @default(cuid())
  influencerId     String
  refreshTokenHash String    @unique
  userAgent        String?
  ip               String?
  createdAt        DateTime  @default(now())
  lastSeenAt       DateTime  @default(now())
  expiresAt        DateTime
  revokedAt        DateTime?

  influencer Influencer @relation(fields: [influencerId], references: [id], onDelete: Cascade)

  @@index([influencerId])
  @@map("influencer_sessions")
}

model InfluencerSnsAccount {
  id            String   @id @default(cuid())
  influencerId  String
  snsType       SnsType
  handle        String
  followerCount Int      @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  influencer Influencer @relation(fields: [influencerId], references: [id], onDelete: Cascade)

  @@unique([influencerId, snsType])
  @@map("influencer_sns_accounts")
}

model InfluencerConsent {
  id           String   @id @default(cuid())
  influencerId String
  termsVersion String
  agreedItems  String[]
  agreedAt     DateTime @default(now())
  ip           String?
  userAgent    String?

  influencer Influencer @relation(fields: [influencerId], references: [id], onDelete: Cascade)

  @@index([influencerId, termsVersion])
  @@map("influencer_consents")
}

model InfluencerBankAccount {
  id                String               @id @default(cuid())
  influencerId      String               @unique
  ownerType         InfluencerEntityType
  bankCode          String
  bankName          String
  branchName        String
  accountType       JpAccountType
  accountNumber     String
  accountHolderKana String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  influencer Influencer @relation(fields: [influencerId], references: [id], onDelete: Cascade)

  @@map("influencer_bank_accounts")
}

model CampaignApplication {
  id           String            @id @default(cuid())
  campaignId   String
  influencerId String
  status       ApplicationStatus @default(APPLIED)

  appliedAt    DateTime  @default(now())
  reviewedAt   DateTime?
  reviewedById String?
  rejectReason String?

  trackingCarrier String?
  trackingNumber  String?
  shippedAt       DateTime?
  deliveredAt    DateTime?
  receivedAt     DateTime?
  completedAt    DateTime?

  selectedSnsTypes SnsType[] @default([])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  campaign   Campaign        @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  influencer Influencer      @relation(fields: [influencerId], references: [id], onDelete: Restrict)
  posts      SubmittedPost[]

  @@unique([campaignId, influencerId])
  @@index([campaignId, status])
  @@index([influencerId, status])
  @@map("campaign_applications")
}

model SubmittedPost {
  id                  String    @id @default(cuid())
  applicationId       String
  snsType             SnsType
  url                 String
  submittedAt         DateTime  @default(now())
  insightLikes        Int?
  insightComments     Int?
  insightShares       Int?
  insightReposts      Int?
  insightSaves        Int?
  insightViews        Int?
  insightReach        Int?
  insightProfileViews Int?
  insightSubmittedAt  DateTime?
  updatedAt           DateTime  @updatedAt

  reviewStatus PostReviewStatus @default(PENDING)
  reviewedAt   DateTime?
  reviewedById String?

  settledAt        DateTime?
  settledAmountJpy Int?
  settledById      String?

  application CampaignApplication      @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  rejections  SubmittedPostRejection[]
  attachments SubmittedPostAttachment[]

  @@unique([applicationId, snsType])
  @@index([applicationId])
  @@index([reviewStatus])
  @@map("submitted_posts")
}

model SubmittedPostAttachment {
  id          String   @id @default(cuid())
  postId      String
  objectKey   String   @unique
  contentType String
  sizeBytes   Int
  uploadedAt  DateTime @default(now())

  post SubmittedPost @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@index([postId])
  @@map("submitted_post_attachments")
}

model SubmittedPostRejection {
  id           String   @id @default(cuid())
  postId       String
  comment      String
  rejectedAt   DateTime @default(now())
  rejectedById String?

  post SubmittedPost @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@index([postId])
  @@map("submitted_post_rejections")
}

model Notice {
  id          String   @id @default(cuid())
  title       String
  contentHtml String
  publishedAt DateTime
  authorId    String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  author AdminUser @relation(fields: [authorId], references: [id])

  @@index([publishedAt])
  @@map("notices")
}
