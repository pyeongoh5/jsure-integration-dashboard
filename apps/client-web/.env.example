# 표시 언어를 결정합니다. ko(개발/한국어) | ja(프로덕션/일본어). 기본값 ko.
VITE_I18N_REGION=ko

# Vercel에 배포할 때 운영 API 도메인을 지정합니다.
# 비워두면 vite.config.ts의 dev 프록시(/api → localhost:3000)를 사용합니다.
VITE_API_BASE_URL=

# Sentry — 비우면 초기화 자체를 건너뜁니다.
VITE_SENTRY_DSN=
VITE_SENTRY_ENVIRONMENT=
VITE_SENTRY_RELEASE=
VITE_SENTRY_TRACES_SAMPLE_RATE=

# Sentry source map 업로드 (빌드 타임).
# Vercel Sentry Integration이 운영 환경에 자동 주입합니다. 로컬 빌드에선 비워둡니다.
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=
