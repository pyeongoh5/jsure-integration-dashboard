{
  "name": "jsure-integration-dashboard",
  "private": true,
  "packageManager": "pnpm@9.12.0",
  "scripts": {
    "dev": "turbo dev --filter=@jsure/admin-web --filter=@jsure/api",
    "dev:admin": "turbo dev --filter=@jsure/admin-web --filter=@jsure/api",
    "dev:client": "turbo dev --filter=@jsure/client-web --filter=@jsure/api",
    "dev:web": "turbo dev --filter=@jsure/client-web --filter=@jsure/admin-web",
    "dev:all": "turbo dev",
    "dev:api": "turbo dev --filter=@jsure/api",
    "dev:admin-web": "turbo dev --filter=@jsure/admin-web",
    "dev:client-web": "turbo dev --filter=@jsure/client-web",
    "dev:client-web:kr": "VITE_I18N_REGION=kr turbo dev --filter=@jsure/client-web",
    "dev:client-web:jp": "VITE_I18N_REGION=jp turbo dev --filter=@jsure/client-web",
    "build": "turbo build",
    "lint": "turbo lint",
    "typecheck": "turbo typecheck",
    "test": "turbo test",
    "clean": "turbo clean && rm -rf node_modules",
    "db:migrate": "pnpm --filter @jsure/api exec prisma migrate dev",
    "db:deploy": "pnpm --filter @jsure/api exec prisma migrate deploy",
    "db:studio": "pnpm --filter @jsure/api exec prisma studio",
    "db:generate": "pnpm --filter @jsure/api exec prisma generate"
  },
  "devDependencies": {
    "turbo": "^2.3.0",
    "typescript": "^5.6.3",
    "prettier": "^3.3.3"
  },
  "engines": {
    "node": ">=20"
  }
}
